# --- Database Credentials (Internal Container) ---
POSTGRES_USER=finance_admin
POSTGRES_PASSWORD=finance_local_pass_1234
POSTGRES_DB=finance_manager

# --- Backend Application Config ---
DB_HOST=db
DB_USER=finance_admin
DB_PASSWORD=finance_local_pass_1234
DB_NAME=finance_manager
DB_PORT=5432

# --- Security ---
# Generate a long random string for production
JWT_SECRET=your_super_secret_jwt_key_change_me

# --- External Port Mapping ---
# Port to access the Backend API from host
BACKEND_PORT=8080
# Port to access the Frontend Website from host
FRONTEND_PORT=80
# Port to access the Database from host (optional)
DB_EXTERNAL_PORT=5433
